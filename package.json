{
  "name": "coffeebar",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "mobile",
    "packages/contracts"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "contracts:test": "npm --workspace @coffeebar/contracts run test",
    "contracts:typecheck": "npm --workspace @coffeebar/contracts run typecheck",
    "mobile:test": "npm --workspace @coffeebar/mobile run test",
    "mobile:typecheck": "npm --workspace @coffeebar/mobile run typecheck",
    "mobile:build": "npm --workspace @coffeebar/mobile run build",
    "mobile:sync": "npm run mobile:build && npm --workspace @coffeebar/mobile run cap:sync",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@amplitude/analytics-browser": "^2.45.1",
    "@better-auth/prisma-adapter": "1.6.23",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-tabs": "1.1.17",
    "@vercel/blob": "2.6.1",
    "@coffeebar/contracts": "workspace:*",
    "better-auth": "1.6.23",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "gsap": "^3.15.0",
    "jose": "6.2.3",
    "lucide-react": "1.24.0",
    "mixpanel-browser": "^2.81.0",
    "next": "16.2.10",
    "pg": "8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.9.2",
    "resend": "6.17.2",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "thinkingdata-browser": "^2.5.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
