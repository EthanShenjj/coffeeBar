# Database (use an unpooled URL for migrations when your provider supplies one)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Public Web and Better Auth
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=
AUTH_REQUIRE_EMAIL_VERIFICATION=false
MOBILE_ALLOWED_ORIGIN=capacitor://localhost

# iOS app configuration
IOS_MINIMUM_VERSION=1.0.0
IOS_MAINTENANCE_MODE=false
NEXT_PUBLIC_SUPPORT_EMAIL=support@coffeebar.app

# APNs provider credentials (server only; never use VITE_ or NEXT_PUBLIC_ prefixes)
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY_BASE64=
APNS_BUNDLE_ID=com.coffeebar.app
APNS_ENVIRONMENT=development

# Email, upload, and seed administration
RESEND_API_KEY=
EMAIL_FROM=
BLOB_READ_WRITE_TOKEN=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Public Web analytics identifiers
NEXT_PUBLIC_AMPLITUDE_API_KEY=
NEXT_PUBLIC_MIXPANEL_PROJECT_TOKEN=
NEXT_PUBLIC_THINKINGDATA_APP_ID=
NEXT_PUBLIC_THINKINGDATA_SERVER_URL=
THINKINGDATA_EXPERIMENT_FETCH_URL=
THINKINGDATA_WEBHOOK_SECRET=
